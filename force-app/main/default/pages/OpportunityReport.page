<apex:page standardController="Opportunity" extensions="OpportunityReportController" renderAs="pdf" applyHtmlTag="false" showHeader="false" sidebar="false" standardStylesheets="false">
<html>
<head>
    <style>
        @page {
            size: A4;
            margin: 1.5cm 2cm 2cm 2cm;
            
            @bottom-center {
                content: "Page " counter(page) " of " counter(pages);
                font-size: 8pt;
                color: #666;
            }
        }
        
        body {
            font-family: 'Times New Roman', Times, serif;
            font-size: 11pt;
            color: #000;
            line-height: 1.4;
        }
        
        .logo-header {
            display: table;
            width: 100%;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid #ccc;
        }
        
        .logo-cell {
            display: table-cell;
            width: 10%;
            text-align: left;
            padding: 10px;
            vertical-align: middle;

            /* max logo area */
            max-width: 180px;
            max-height: 60px;
        }

        
        .logo-cell img {
            max-height: 60px;
            max-width: 180px;
        }
        
        .title-bar {
            background-color: #3d3d3d;
            color: white;
            text-align: center;
            padding: 12px;
            font-size: 18pt;
            font-weight: bold;
            letter-spacing: 2px;
            margin-bottom: 20px;
        }
        
        .info-row {
            display: table;
            width: 100%;
            margin-bottom: 8px;
        }
        
        .info-cell {
            display: table-cell;
            width: 50%;
            padding: 3px 0;
        }
        
        .info-label {
            font-weight: normal;
        }
        
        .info-value {
            font-weight: normal;
        }
        
        .section-title {
            text-decoration: underline;
            font-weight: bold;
            margin: 20px 0 10px 0;
        }
        
        .field-row {
            display: table;
            width: 100%;
            margin-bottom: 5px;
        }
        
        .field-cell {
            display: table-cell;
            padding: 3px 0;
        }
        
        .field-cell-label {
            width: 35%;
        }
        
        .field-cell-value {
            width: 65%;
        }
        
        .greeting {
            margin: 15px 0;
        }
        
        .units-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        
        .units-table th {
            background-color: #f5f5f5;
            border: 1px solid #333;
            padding: 8px;
            text-align: center;
            font-weight: bold;
            font-size: 10pt;
        }
        
        .units-table td {
            border: 1px solid #333;
            padding: 8px;
            text-align: center;
            font-size: 10pt;
        }
        
        .units-table .total-row {
            background-color: #999;
            color: white;
            font-weight: bold;
        }
        
        .charges-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        
        .charges-table th {
            background-color: #f5f5f5;
            border: 1px solid #333;
            padding: 8px;
            text-align: left;
            font-weight: bold;
            font-size: 10pt;
        }
        
        .charges-table td {
            border: 1px solid #333;
            padding: 8px;
            text-align: left;
            font-size: 10pt;
        }
        
        .page-break {
            page-break-before: always;
        }
    </style>
</head>

<body>
    <table style="width:100%; border-collapse:collapse; margin-bottom:20px;">
        <tr>
            <!-- LEFT LOGO -->
            <td style="
                width:180px;
                height:60px;
                overflow:hidden;
                vertical-align:middle;
            ">
                <img src="{!$Resource.AlameriahReportLogo}"
                    style="
                        height:60px;
                        width:auto;
                        display:block;
                    " />
            </td>


            

            <!-- RIGHT EMPTY SPACE (BALANCE) -->
            <td style="width:180px;"></td>
        </tr>
    </table>

    
    <div class="title-bar">
        Sales Offer
    </div>
    
    <div class="info-row">
        <div class="info-cell">
            <span class="info-label">Date : </span>
            <span class="info-value">{!TODAY()}</span>
        </div>
        <div class="info-cell" style="text-align: right;">
            <span class="info-label">Deal Number : </span>
            <span class="info-value">
                <apex:outputText value="{!opportunity.Deal_Number__c}"/>
            </span>
        </div>
    </div>
    
    <div class="info-row">
        <div class="info-cell">
            <span class="info-label">Attention : </span>
            <span class="info-value">
                <apex:outputText value="{!opportunity.Primary_Contact__c}"/>
            </span>
        </div>
        <div class="info-cell" style="text-align: right;">
            <!-- Additional info can go here -->
        </div>
    </div>
    
    <div class="info-row">
        <div class="info-cell">
            <span class="info-label">Email : </span>
            <span class="info-value">
                <apex:outputText value="{!opportunity.AccountId}"/>
            </span>
        </div>
        <div class="info-cell" style="text-align: right;">
            <span class="info-label">Phone No : </span>
            <span class="info-value">
                <!-- Phone field if available -->
            </span>
        </div>
    </div>
    
    <div class="section-title">Subjected to :</div>
    
    <div class="field-row">
        <div class="field-cell field-cell-label">
            <span class="info-label">Site</span>
        </div>
        <div class="field-cell field-cell-value">
            <span class="info-label">: </span>
            <span class="info-value">
                <apex:outputText value="{!opportunity.Site__c}"/>
            </span>
        </div>
    </div>
    
    <div class="field-row">
        <div class="field-cell field-cell-label">
            <span class="info-label">Opportunity Name</span>
        </div>
        <div class="field-cell field-cell-value">
            <span class="info-label">: </span>
            <span class="info-value">
                <apex:outputText value="{!opportunity.Name}"/>
            </span>
        </div>
    </div>
    
    <div class="greeting">
        Dear Valued Customer,
    </div>
    
    <div style="margin: 10px 0;">
        <strong>Property Details:</strong>
    </div>
    
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px;">
        <apex:repeat value="{!opportunityFields}" var="oppField">
            <tr>
                <td style="padding: 5px 10px; width: 35%; border-bottom: 1px solid #eee;">
                    <strong>{!oppField.label}</strong>
                </td>
                <td style="padding: 5px 10px; width: 65%; border-bottom: 1px solid #eee;">
                    <apex:outputText value="{!oppField.formattedValue}" escape="false"/>
                </td>
            </tr>
        </apex:repeat>
    </table>
    
    <apex:outputPanel rendered="{!hasPaymentSchedules}">
        <div style="margin-top: 25px;">
            <strong>Payment Schedule:</strong>
        </div>
        
        <table class="units-table">
            <thead>
                <tr>
                    <apex:repeat value="{!paymentScheduleFields}" var="headerField">
                        <th>{!headerField.label}</th>
                    </apex:repeat>
                </tr>
            </thead>
            <tbody>
                <apex:repeat value="{!paymentScheduleRecords}" var="scheduleRecord">
                    <tr>
                        <apex:repeat value="{!scheduleRecord.fields}" var="cellField">
                            <td>
                                <apex:outputText value="{!cellField.formattedValue}"/>
                            </td>
                        </apex:repeat>
                    </tr>
                </apex:repeat>
            </tbody>
        </table>
    </apex:outputPanel>
    
    <apex:outputPanel rendered="{!hasOtherCharges}">
        <div style="margin-top: 25px;">
            <strong>Other Charges:</strong>
        </div>
        
        <table class="charges-table">
            <thead>
                <tr>
                    <apex:repeat value="{!otherChargeFields}" var="headerField">
                        <th>{!headerField.label}</th>
                    </apex:repeat>
                </tr>
            </thead>
            <tbody>
                <apex:repeat value="{!otherChargeRecords}" var="chargeRecord">
                    <tr>
                        <apex:repeat value="{!chargeRecord.fields}" var="cellField">
                            <td>
                                <apex:outputText value="{!cellField.formattedValue}"/>
                            </td>
                        </apex:repeat>
                    </tr>
                </apex:repeat>
            </tbody>
        </table>
    </apex:outputPanel>
    
    <div style="margin-top: 30px; font-size: 10pt; color: #666;">
        <em>This report was automatically generated from Salesforce on {!NOW()}</em>
    </div>
</body>
</html>
</apex:page>